# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# Groq API (required)
GROQ_API_KEY=your_groq_api_key_here

# Snowflake (required for live mode; not needed if SNOWFLAKE_MOCK=true)
SNOWFLAKE_ACCOUNT=your_account_here
SNOWFLAKE_USER=your_user_here
SNOWFLAKE_TOKEN=your_pat_here
SNOWFLAKE_AUTHENTICATOR=snowflake
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=CS5542_WEEK5
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Set to true to run fully offline (no Snowflake needed)
SNOWFLAKE_MOCK=false

# Reproducibility seed (matches config.yaml)
RANDOM_SEED=42
